{
  "name": "mybooze",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prebuild": "pnpm run generate:types",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsgo --noEmit",
    "typecheck:legacy": "tsc --noEmit",
    "generate:types": "NODE_OPTIONS=--conditions=react-server payload generate:types",
    "migrate": "NODE_OPTIONS=--conditions=react-server payload migrate",
    "migrate:create": "NODE_OPTIONS=--conditions=react-server payload migrate:create",
    "seed": "NODE_OPTIONS=--conditions=react-server tsx scripts/seed.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1",
    "@sentry/nextjs": "10.61.0",
    "maplibre-gl": "5.24.0",
    "next": "16.2.10",
    "payload": "3.84.1",
    "pino": "10.3.1",
    "posthog-js": "1.393.5",
    "posthog-node": "5.38.5",
    "razorpay": "2.9.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-map-gl": "8.1.1",
    "resend": "^6.14.0",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@types/node": "22.10.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@typescript/native-preview": "beta",
    "dotenv": "17.4.2",
    "pino-pretty": "13.1.3",
    "server-only": "^0.0.1",
    "tsx": "4.19.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
