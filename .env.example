# Payload
PAYLOAD_SECRET=replace-with-openssl-rand-hex-32
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Postgres
DATABASE_URI=postgres://mybooz:mybooz@localhost:5432/mybooz

# S3 (use real AWS or any S3-compatible — MinIO, R2, Tigris, etc.)
S3_BUCKET=mybooz-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Leave S3_ENDPOINT blank for AWS; set for MinIO/R2
S3_ENDPOINT=
