# Payload
PAYLOAD_SECRET=replace-with-openssl-rand-hex-32
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Email (magic-link auth) ---
# Owners sign in via a one-time link emailed to them (passwordless).
# Without these, the link is logged to the server console instead of emailed — fine for dev.
# Create an API key at resend.com and verify a sending domain.
RESEND_API_KEY=
EMAIL_FROM="Mybooz <login@yourdomain.com>"

# Postgres
DATABASE_URI=postgres://mybooz:mybooz@localhost:5432/mybooz

# S3 (use real AWS or any S3-compatible — MinIO, R2, Tigris, etc.)
S3_BUCKET=mybooz-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Leave S3_ENDPOINT blank for AWS; set for MinIO/R2
S3_ENDPOINT=

# --- Observability (all optional — without them, observability is a no-op) ---

# Sentry — error + performance monitoring.
# Create a project at sentry.io, copy the DSN.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Optional override of environment label sent to Sentry (defaults to NODE_ENV).
SENTRY_ENV=
NEXT_PUBLIC_SENTRY_ENV=
# For source-map upload during `pnpm build` (set in CI / prod env, not locally).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog — product analytics + pageviews + web vitals.
# Create a project at posthog.com, copy the project API key.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side key (often same as NEXT_PUBLIC_POSTHOG_KEY for project-scoped events).
POSTHOG_KEY=

# Pino logger
# debug | info | warn | error  (default: debug in dev, info in prod)
LOG_LEVEL=

# --- Maps ---
# Optional. Defaults to https://demotiles.maplibre.org/style.json (dev only — rate-limited).
# For production, use a MapTiler / Stadia / Carto style URL with your API key.
# Examples:
#   https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_KEY
#   https://tiles.stadiamaps.com/styles/alidade_smooth.json?api_key=YOUR_KEY
NEXT_PUBLIC_MAP_STYLE_URL=

# --- Razorpay (billing) ---
# Without these, the owner-dashboard upgrade button shows a friendly "billing disabled" message.
# Create plans in Razorpay dashboard (Subscriptions → Plans), copy the plan IDs.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_VERIFIED=
RAZORPAY_PLAN_FEATURED=
